# Copy to .env.railway for docker-compose.railway.yml
# Railway Dashboard → each service → Variables (do not commit .env.railway)

# --- Web service ---
# Railway: API の公開 URL（末尾スラッシュなし・必須）
# API_URL=https://YOUR-API-SERVICE.up.railway.app
#
# docker-compose.railway.yml ローカル起動: 未設定で OK（既定 http://api:8080）
# ※ localhost:8080 は Web コンテナ内からは API に届かないので Compose では使わない

# --- Optional (compose ports) ---
API_PORT=8080
WEB_PORT=3000

# --- API service (optional) ---
# ブラウザから API に直接アクセスする場合の CORS（カンマ区切り）
# Railway Web の公開 URL を含める例:
# ALLOWED_ORIGINS=https://YOUR-WEB-SERVICE.up.railway.app,http://localhost:3000

# --- Railway 変数の参照例（Dashboard で設定、ファイルには書かない） ---
# Web サービス:
#   API_URL = https://${{api.RAILWAY_PUBLIC_DOMAIN}}
#   （api は API サービス名。サービス名に合わせて変更）
#
# API サービス:
#   PORT は Railway が自動注入（通常は設定不要）
