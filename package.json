{
  "name": "dental-care-dx",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx scripts/run-api.ts",
    "dev:web": "cd frontend && npm run dev",
    "build:web": "cd frontend && npm run build",
    "codegen": "cd frontend && npm run codegen",
    "install:all": "cd frontend && npm install",
    "typecheck": "npm run typecheck:scripts && npm run typecheck:web",
    "typecheck:scripts": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "cd frontend && npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
